{
  "manifest_version": 3,
  "name": "Reel Inbox Scraper",
  "version": "0.1.0",
  "description": "Scrapes Instagram DM thread shared posts into Post objects for the Reels Reader pipeline.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://www.instagram.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/direct/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
